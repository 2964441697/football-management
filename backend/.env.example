# 足球管理系统后端配置示例
# 复制此文件为 .env 并填写实际值

# ========== 环境配置 ==========
# 运行环境: development / production / testing
FLASK_ENV=development

# ========== 数据库配置 ==========
# SQLite (开发环境)
# DATABASE_URL=sqlite:///football.db

# MySQL (生产环境推荐)
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/football_db

# PostgreSQL
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/football_db

# ========== 安全配置 ==========
# Flask 密钥 (生产环境必须修改!)
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-random-string

# JWT 密钥 (生产环境必须修改!)
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-random-string

# ========== CORS 配置 ==========
# 允许的前端来源地址，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
