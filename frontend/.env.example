# 前端环境配置示例
# 复制此文件为 .env.development (开发) 或 .env.production (生产)

# API 基础 URL
# 开发环境使用 /api (通过 vite 代理)
# 生产环境根据实际部署配置
VITE_API_BASE_URL=/api

# 后端服务地址
# 开发环境: http://localhost:5000
# 生产环境: 根据实际部署填写
VITE_BACKEND_URL=http://localhost:5000

# 静态资源基础 URL（用于头像等静态文件）
# 开发环境: http://localhost:5000
# 生产环境: 可配置为 CDN 地址
VITE_STATIC_BASE_URL=http://localhost:5000
